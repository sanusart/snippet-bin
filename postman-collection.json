{
  "info": {
    "name": "SnippetBin API",
    "description": "API for SnippetBin - Gists-like snippets app",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/user",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Gists",
      "item": [
        {
          "name": "List Gists",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/gists",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Starred Gists",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/gists/starred",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Gist",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/gists/:id",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ]
          }
        },
        {
          "name": "Create Gist",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/gists",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"My first gist\",\n  \"public\": false,\n  \"files\": {\n    \"hello.js\": {\n      \"content\": \"console.log('Hello, World!');\"\n    }\n  }\n}"
            }
          }
        },
        {
          "name": "Update Gist",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/gists/:id",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\",\n  \"files\": {\n    \"hello.js\": {\n      \"content\": \"console.log('Updated!');\"\n    }\n  }\n}"
            }
          }
        },
        {
          "name": "Delete Gist",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/gists/:id",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ]
          }
        },
        {
          "name": "Star Gist",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/gists/:id/star",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ]
          }
        },
        {
          "name": "Unstar Gist",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/gists/:id/star",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Tokens",
      "item": [
        {
          "name": "List Tokens",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tokens",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ]
          }
        },
        {
          "name": "Create Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/tokens",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"My API token\"\n}"
            }
          }
        },
        {
          "name": "Delete Token",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/tokens/:id",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/:username"
          }
        }
      ]
    }
  ]
}
