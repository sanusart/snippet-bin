{
  "info": {
    "name": "SnippetBin API (updated)",
    "description": "API requests for SnippetBin. Register or log in to get the first `sb_tkn_*` token, then use that token when exercising the authenticated endpoints below.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "gistId",
      "value": ""
    },
    {
      "key": "tokenId",
      "value": ""
    },
    {
      "key": "username",
      "value": "snippet_user"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"snippet_user\",\n  \"email\": \"snippet@example.com\",\n  \"name\": \"Snippet User\",\n  \"password\": \"securePass123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login (email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"snippet@example.com\",\n  \"password\": \"securePass123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "response": []
        },
        {
          "name": "Who am I",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/auth/user"
          }
        },
        {
          "name": "Update name",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/user"
          }
        }
      ]
    },
    {
      "name": "Gists",
      "item": [
        {
          "name": "List gists",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/gists"
          }
        },
        {
          "name": "List starred",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/gists/starred"
          }
        },
        {
          "name": "Get gist",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/gists/{{gistId}}"
          }
        },
        {
          "name": "Create gist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Hello from Postman\",\n  \"public\": false,\n  \"files\": {\n    \"hello.js\": {\n      \"content\": \"console.log('Hello world');\",\n      \"language\": \"javascript\"\n    }\n  }\n}"
            },
            "url": "{{baseUrl}}/api/gists"
          }
        },
        {
          "name": "Update gist",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated via Postman\",\n  \"files\": {\n    \"hello.js\": {\n      \"content\": \"console.log('Updated!');\"\n    }\n  }\n}"
            },
            "url": "{{baseUrl}}/api/gists/{{gistId}}"
          }
        },
        {
          "name": "Delete gist",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/gists/{{gistId}}"
          }
        },
        {
          "name": "Star gist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/gists/{{gistId}}/star"
          }
        },
        {
          "name": "Unstar gist",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/gists/{{gistId}}/star"
          }
        }
      ]
    },
    {
      "name": "Tokens",
      "item": [
        {
          "name": "List tokens",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/tokens"
          }
        },
        {
          "name": "Create token (authenticated)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"My Postman token\"\n}"
            },
            "url": "{{baseUrl}}/api/tokens"
          }
        },
        {
          "name": "Create token (credentials)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"snippet@example.com\",\n  \"password\": \"securePass123\",\n  \"note\": \"Postman credential token\"\n}"
            },
            "url": "{{baseUrl}}/api/tokens"
          }
        },
        {
          "name": "Delete token",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "token {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/tokens/{{tokenId}}"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get user profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/{{username}}"
          }
        }
      ]
    }
  ]
}
